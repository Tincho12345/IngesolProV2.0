@model List<WebIngesol.Models.VisibleClient>

@{
    Layout = User.Identity?.IsAuthenticated == true
        ? "~/Views/Shared/_Layout.cshtml"
        : "~/Views/Shared/_LayoutLanding.cshtml";

    ViewData["Title"] = "Home";
}

<partial name="Sections/_HeroSection" />
<partial name="Sections/_About" />
<partial name="Sections/_Clients" model="Model" />
<partial name="Sections/_Features" />
<partial name="Sections/_Features-Cards" />
<partial name="Sections/_Cta-Testimonials" />
<partial name="Sections/_Services" />
<partial name="Sections/_Pricing" />
<partial name="Sections/_Faq" />
<partial name="Sections/_Portfolio" />
<partial name="Sections/_Team" />
<partial name="Sections/_Contact" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>
}