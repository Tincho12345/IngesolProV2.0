@model List<WebIngesol.Models.VisibleClient>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor httpAcc

@{
    var rol = httpAcc.HttpContext?.Session.GetString("Role") ?? "";
    var isAdmin = rol.Trim() == "🛡️ Admin";
    var clientes = Model?.Where(x => !string.IsNullOrWhiteSpace(x?.Imagen)).ToList();
}

<section id="clients" class="hero section dark-background">
    <div class="hero-content">
        <div class="container position-relative">
            <div class="row justify-content-center text-center mb-4">
                <div class="col-lg-8">
                    <div class="hero-glass-card" data-aos="fade-up">
                        <span class="subtitle">Nuestros Clientes</span>
                        <h2>Empresas que confían en INGESOL</h2>
                        <p>
                            Trabajamos junto a organizaciones de distintos sectores,
                            brindando soluciones de ingeniería confiables, seguras y eficientes.
                        </p>

                        @if (isAdmin)
                        {
                            <button class="btn-glass btn-glass-outline px-4 mt-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#uploadClienteModal">
                                Agregar Cliente
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div id="clients-container">
                @await Html.PartialAsync("Sections/_ClientesPartial", Model)
            </div>
        </div>
    </div>
</section>

@if (isAdmin)
{
    @* ========================= MODAL AGREGAR CLIENTE ========================= *@
    <div class="modal fade" id="uploadClienteModal" tabindex="-1" aria-labelledby="uploadClienteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-glass position-relative">

                <span class="modal-close"
                      data-bs-dismiss="modal"
                      style="position:absolute; top:10px; right:10px; font-size:30px; color:white; cursor:pointer;">
                    &times;
                </span>

                <div class="modal-header text-center border-0">
                    <h5 class="modal-title w-100 fw-bold text-white" id="uploadClienteModalLabel">
                        Agregar Nuevo Cliente
                    </h5>
                </div>

                <div class="modal-body">
                    <form asp-controller="VisibleClients"
                          asp-action="Upload"
                          method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="text"
                               name="nombre"
                               class="form-control mb-3"
                               placeholder="Nombre de la empresa"
                               required />

                        <input type="file"
                               name="imageFile"
                               class="form-control mb-3"
                               accept="image/*"
                               required />

                        @* Partial para links sociales *@
                        @await Html.PartialAsync("Sections/_SocialLinks", new ViewDataDictionary(ViewData) { { "prefix", "" } })

                        <button type="submit" class="btn-glass btn-glass-outline px-4 w-100 mt-3">
                            Subir Cliente
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* ========================= MODAL EDITAR CLIENTE ========================= *@
    <div class="modal fade" id="editClienteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-glass position-relative">

                <span class="modal-close"
                      data-bs-dismiss="modal"
                      style="position:absolute; top:10px; right:10px; font-size:30px; color:white; cursor:pointer;">
                    &times;
                </span>

                <div class="modal-header text-center border-0">
                    <h5 class="modal-title w-100 fw-bold text-white">
                        Editar Cliente
                    </h5>
                </div>

                <div class="modal-body">
                    <form asp-controller="VisibleClients"
                          asp-action="Edit"
                          method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" id="edit-id" />

                        <input type="text"
                               name="nombre"
                               id="edit-nombre"
                               class="form-control mb-3"
                               placeholder="Nombre de la empresa"
                               required />

                        <input type="file"
                               name="imageFile"
                               class="form-control mb-3"
                               accept="image/*" />

                        @* Partial para links sociales con prefijo "edit" *@
                        @await Html.PartialAsync("Sections/_SocialLinks", new ViewDataDictionary(ViewData) { { "prefix", "edit" } })

                        <button type="submit"
                                class="btn-glass btn-glass-outline px-4 w-100 mt-3">
                            Guardar Cambios
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}