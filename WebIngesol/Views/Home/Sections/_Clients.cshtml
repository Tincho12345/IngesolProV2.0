@model List<WebIngesol.Models.VisibleClient>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor httpAcc

@{
    var rol = httpAcc.HttpContext?.Session.GetString("Role") ?? "";
    var clientes = Model?.Where(x => !string.IsNullOrWhiteSpace(x?.Imagen)).ToList();
    string GetFileName(string path) => System.IO.Path.GetFileName(path)?.Split('?')[0] ?? string.Empty;
}

<section id="clients" class="hero section dark-background">
    <div class="hero-content">
        <div class="container position-relative">

            <!-- Section Title -->
            <div class="row justify-content-center text-center mb-5">
                <div class="col-lg-8">
                    <div class="hero-glass-card" data-aos="fade-up">
                        <span class="subtitle">Nuestros Clientes</span>
                        <h2>Empresas que confían en INGESOL</h2>
                        <p>
                            Trabajamos junto a organizaciones de distintos sectores,
                            brindando soluciones de ingeniería confiables, seguras y eficientes.
                        </p>

                        <button class="btn-glass btn-glass-outline px-4 mt-3"
                                data-bs-toggle="modal"
                                data-bs-target="#uploadClienteModal">
                            Agregar Cliente
                        </button>
                    </div>
                </div>
            </div>

            <!-- Clients Logos Dinámicos -->
            <div class="row justify-content-center">
                @if (clientes?.Any() == true)
                {
                    int delayBase = 100;
                    int delayIncrement = 50;

                    @for (int i = 0; i < clientes.Count; i++)
                    {
                        var c = clientes[i];
                        var delay = delayBase + (i * delayIncrement);
                        var fileName = GetFileName(c.Imagen);
                        var filePath = Url.Content(c.Imagen ?? string.Empty);

                        <div class="col-6 col-md-3 mb-4" data-aos="zoom-in" data-aos-delay="@delay">
                            <div class="glass-card" title="@c.Nombre" style="width: 180px; height: 220px; margin: 0 auto;">
                                <div class="glass-card-body p-2 text-center d-flex flex-column justify-content-between h-100">

                                    <!-- Imagen adaptada -->
                                    <img src="@filePath"
                                         class="img-fluid mb-2"
                                         alt="@fileName"
                                         style="max-height:120px; max-width:160px; object-fit:contain; margin:0 auto;" />

                                    <!-- Redes Sociales -->
                                    @if (!string.IsNullOrWhiteSpace(c.Facebook) ||
                                                                !string.IsNullOrWhiteSpace(c.Twitter) ||
                                                                !string.IsNullOrWhiteSpace(c.Instagram) ||
                                                                !string.IsNullOrWhiteSpace(c.Telegram) ||
                                                                !string.IsNullOrWhiteSpace(c.Website))
                                    {
                                        <div class="d-flex justify-content-center gap-2 mb-2">
                                            @if (!string.IsNullOrWhiteSpace(c.Facebook))
                                            {
                                                <a href="@c.Facebook" target="_blank" class="btn-register">
                                                    <i class="bi bi-facebook"></i>
                                                </a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(c.Twitter))
                                            {
                                                <a href="@c.Twitter" target="_blank" class="btn-register">
                                                    <i class="bi bi-twitter-x"></i>
                                                </a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(c.Instagram))
                                            {
                                                <a href="@c.Instagram" target="_blank" class="btn-register">
                                                    <i class="bi bi-instagram"></i>
                                                </a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(c.Telegram))
                                            {
                                                <a href="@c.Telegram" target="_blank" class="btn-register">
                                                    <i class="bi bi-telegram"></i>
                                                </a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(c.Website))
                                            {
                                                <a href="@c.Website" target="_blank" class="btn-register">
                                                    <i class="bi bi-globe"></i>
                                                </a>
                                            }
                                        </div>
                                    }

                                    <!-- Botón Eliminar -->
                                    <form asp-controller="VisibleClients"
                                          asp-action="Delete"
                                          method="post"
                                          class="delete-client-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="fileName" value="@fileName" />
                                        <button type="submit" class="btn-glass btn-glass-outline px-3 mt-2">
                                            Eliminar
                                        </button>
                                    </form>

                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <p class="text-center text-white-50 mt-4">
                            No hay clientes para mostrar.
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ========================= MODAL AGREGAR CLIENTE ========================= -->
<div class="modal fade" id="uploadClienteModal" tabindex="-1" aria-labelledby="uploadClienteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-glass position-relative">

            <span class="modal-close" data-bs-dismiss="modal"
                  style="position:absolute; top:10px; right:10px; font-size:30px; color:white; cursor:pointer;">
                &times;
            </span>

            <div class="modal-header text-center border-0">
                <h5 class="modal-title w-100 fw-bold text-white" id="uploadClienteModalLabel">
                    Agregar Nuevo Cliente
                </h5>
            </div>

            <div class="modal-body">
                <form asp-controller="VisibleClients" asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <input type="text" name="nombre" class="form-control mb-3" placeholder="Nombre de la empresa" required />
                    <input type="file" name="imageFile" class="form-control mb-3" accept="image/*" required />

                    <div class="mb-3">
                        <label class="form-label fw-bold text-white">Links de redes sociales (opcional)</label>
                        <div class="d-flex flex-column gap-2">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-facebook"></i></span>
                                <input type="url" name="facebook" class="form-control" placeholder="Facebook URL" />
                            </div>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-twitter-x"></i></span>
                                <input type="url" name="twitter" class="form-control" placeholder="X / Twitter URL" />
                            </div>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-instagram"></i></span>
                                <input type="url" name="instagram" class="form-control" placeholder="Instagram URL" />
                            </div>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telegram"></i></span>
                                <input type="url" name="telegram" class="form-control" placeholder="Telegram URL" />
                            </div>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-globe"></i></span>
                                <input type="url" name="website" class="form-control" placeholder="Página web del cliente" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn-glass btn-glass-outline px-4 w-100 mt-3">
                        Subir Cliente
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>