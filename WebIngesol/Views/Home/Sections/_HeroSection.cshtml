@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    var videoFilePath = Env.WebRootPath + "/videos/hero.mp4";
    var videoExists = System.IO.File.Exists(videoFilePath);
}

<style>
    .hero {
        position: relative;
        overflow: hidden;
        @(videoExists ? "height: 100vh;" : "height: auto; background: none;")
    }

    .hero-video {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

        .hero-video video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .hero-content,
    .glass-cards-section {
        position: relative;
        z-index: 2;
        transition: opacity 0.5s ease;
    }

        .hero-content.hidden {
            opacity: 0;
            pointer-events: none;
        }

    .hero-glass-card {
        color: white !important;
    }

    /* Botón flotante sobre el video, centrado horizontal */
    #videoPlayBtn {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none; /* evita clic cuando está oculto */
    }
</style>

<section id="hero" class="hero section">

    @if (videoExists)
    {
        <div class="hero-video">
            <video id="heroVideo" loop playsinline>
                <source src="/videos/hero.mp4?v=@DateTime.Now.Ticks" type="video/mp4">
                <source src="/videos/hero.webm?v=@DateTime.Now.Ticks" type="video/webm">
                Tu navegador no soporta videos HTML5.
            </video>
        </div>
    }

    <div id="heroContent" class="hero-content mb-4">
        <div class="container position-relative">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <div class="hero-glass-card" data-aos="fade-up">
                        <h1 data-aos="fade-up" data-aos-delay="100" style="color: white !important;">
                            Soluciones Integrales en Ingeniería Industrial
                        </h1>
                        <p data-aos="fade-up" data-aos-delay="200" style="color: white !important;">
                            En INGESOL desarrollamos proyectos de ingeniería, confección de planos,
                            diseño y ejecución de montajes electromecánicos con calidad y seguridad.
                            Realizamos instalaciones industriales, movimiento de cargas,
                            inspecciones técnicas y trabajos especializados para optimizar
                            procesos productivos y ampliar la capacidad de tus instalaciones.
                        </p>
                        <div class="hero-buttons" data-aos="fade-up" data-aos-delay="300">
                            <a href="#services" class="btn btn-reserva px-4" onclick="playHeroVideo()">Servicios</a>
                            <a href="#contact" class="btn btn-reserva px-4" onclick="playHeroVideo()">Contactanos</a>
                            <button id="videoToggleBtn" class="btn btn-reserva px-4">Subir Video</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button id="videoPlayBtn" class="btn btn-reserva px-4">
        ▶ Play
    </button>

    <form id="videoUploadForm" method="post" enctype="multipart/form-data" action="/VisibleClients/UploadVideo" style="display:none">
        @Html.AntiForgeryToken()
        <input type="file" id="videoInput" name="videoFile" accept="video/mp4,video/webm,video/ogg">
    </form>

    <div id="videoUploading"
         style="position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999;
                color:white; font-size:22px; display:none; align-items:center;
                justify-content:center; flex-direction:column;">
        <div class="spinner-border text-light mb-3"></div>
        Subiendo video... puede tardar unos segundos
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // ---------------- ELEMENTOS ----------------
            const video = document.getElementById("heroVideo");
            const playBtn = document.getElementById("videoPlayBtn");
            const toggleBtn = document.getElementById("videoToggleBtn");
            const videoInput = document.getElementById("videoInput");
            const heroContent = document.getElementById("heroContent");
            const heroSection = document.getElementById("hero");
            const scrollTopBtn = document.getElementById("scroll-top");

            // ---------------- FUNCIONES DEL VIDEO ----------------
            window.playHeroVideo = () => {
                if (video && video.paused) video.play().catch(() => video.controls = true);
            };

            const togglePlay = () => {
                if (!video) return;
                if (video.paused) video.play().catch(() => video.controls = true);
                else video.pause();
            };

            const updateVideoState = () => {
                if (!video || !playBtn || !heroContent) return;
                if (video.paused) {
                    heroContent.classList.remove("hidden");
                    playBtn.textContent = "▶ Play";
                } else {
                    heroContent.classList.add("hidden");
                    playBtn.textContent = "⏸ Pause";
                }
            };

            // ---------------- EVENTOS BOTONES ----------------
            if (playBtn) playBtn.addEventListener("click", togglePlay);
            if (video) {
                video.addEventListener("play", updateVideoState);
                video.addEventListener("pause", updateVideoState);
            }
            if (toggleBtn && videoInput) toggleBtn.addEventListener("click", () => videoInput.click());

            // ---------------- SUBIR VIDEO ----------------
            if (videoInput) {
                videoInput.addEventListener("change", async () => {
                    const file = videoInput.files[0];
                    if (!file) return;

                    if (video) {
                        video.pause();
                        video.querySelectorAll("source").forEach(src => src.src = URL.createObjectURL(file));
                        video.load();
                    }

                    const formData = new FormData();
                    formData.append("videoFile", file);
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    if (token) formData.append("__RequestVerificationToken", token);

                    try {
                        Swal.fire({ title: "Subiendo video...", allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        const res = await fetch("/VisibleClients/UploadVideo", { method: "POST", body: formData });
                        const data = await res.json();
                        Swal.close();

                        if (data?.fileName && video) {
                            await Swal.fire({ title: "Video subido correctamente", icon: "success", timer: 1500, showConfirmButton: false });
                            video.querySelectorAll("source").forEach(src => src.src = `/videos/${data.fileName}?v=${Date.now()}`);
                            video.load();
                        }
                    } catch (err) {
                        Swal.close();
                        await Swal.fire({ title: "Error subiendo el video", icon: "error" });
                    }
                });
            }

            // ---------------- SIGNALR ----------------
            if (!window.signalrClientesInit && typeof signalR !== "undefined") {
                window.signalrClientesInit = true;
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/clientsHub")
                    .withAutomaticReconnect()
                    .build();

                connection.on("VideoActualizado", fileName => {
                    if (!video) return;
                    video.querySelectorAll("source").forEach(src => src.src = `/videos/${fileName}?v=${Date.now()}`);
                    video.load();
                });

                connection.start()
                    .then(() => console.log("Conectado a SignalR"))
                    .catch(err => console.error("Error conectando a SignalR:", err));
            }

            // ---------------- FADE BOTÓN PLAY SEGÚN VISIBILIDAD DEL SCROLL-TOP ----------------
            if (playBtn && heroSection && scrollTopBtn) {
                const fadeDistance = 50; // margen antes de desaparecer

                const updatePlayBtn = () => {
                    const heroRect = heroSection.getBoundingClientRect();
                    const heroBottom = heroRect.bottom;

                    // El arrow es visible si offsetParent !== null
                    const scrollTopVisible = scrollTopBtn.offsetParent !== null;

                    let opacity = 1;

                    if (scrollTopVisible || heroBottom < fadeDistance) {
                        // Fade progresivo: cuando heroBottom < fadeDistance*2 empieza a desaparecer
                        opacity = Math.max(0, (heroBottom - 0) / fadeDistance);
                    }

                    playBtn.style.opacity = opacity;
                    playBtn.style.pointerEvents = opacity > 0.1 ? "auto" : "none";
                };

                // Ejecutar al cargar, scroll y resize
                updatePlayBtn();
                window.addEventListener("scroll", updatePlayBtn);
                window.addEventListener("resize", updatePlayBtn);
            }
        });
    </script>

</section>