@{
    var prefix = ViewData["prefix"]?.ToString() ?? "";
}

<label class="form-label fw-bold text-white">
    Links de redes sociales (opcional)
</label>

<div class="d-flex flex-column gap-2 mb-3">

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-facebook"></i></span>
        <input type="url"
               id="@prefix-facebook"
               name="facebook"
               class="form-control"
               placeholder="Facebook URL">
    </div>

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-twitter-x"></i></span>
        <input type="url"
               id="@prefix-twitter"
               name="twitter"
               class="form-control"
               placeholder="X / Twitter URL">
    </div>

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-instagram"></i></span>
        <input type="url"
               id="@prefix-instagram"
               name="instagram"
               class="form-control"
               placeholder="Instagram URL">
    </div>

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-telegram"></i></span>
        <input type="url"
               id="@prefix-telegram"
               name="telegram"
               class="form-control"
               placeholder="Telegram URL">
    </div>

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-linkedin"></i></span>
        <input type="url"
               id="@prefix-linkedin"
               name="linkedin"
               class="form-control"
               placeholder="LinkedIn URL">
    </div>

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-whatsapp"></i></span>
        <input type="text"
               id="@prefix-whatsapp"
               name="whatsapp"
               class="form-control"
               placeholder="WhatsApp (ej: 5493764123456)">
    </div>

    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-globe"></i></span>
        <input type="url"
               id="@prefix-website"
               name="website"
               class="form-control"
               placeholder="Página web del cliente">
    </div>

</div>