@inject Microsoft.AspNetCore.Http.IHttpContextAccessor httpAcc
@using WebIngesol.ConstantsRoute
@using System.Globalization

@{
    var rawFirstName = httpAcc.HttpContext?.Session.GetString("Nombre") ?? "";
    var firstName = CultureInfo.CurrentCulture.TextInfo.ToTitleCase(rawFirstName.ToLower());

    var rol = httpAcc.HttpContext?.Session.GetString("Role") ?? "";
    var imagePath = httpAcc.HttpContext?.Session.GetString("ImagePath");

    var backendOrigin = CT.Base;

    var profileImageUrl = string.IsNullOrEmpty(imagePath)
        ? Url.Content("~/images/SinFoto.png")
        : $"{backendOrigin}{(imagePath.StartsWith("/") ? "" : "/")}{imagePath}";
}

<div class="collapse navbar-collapse justify-content-between" id="mainNavbar">

    <!-- MENÚ PRINCIPAL -->
    @await Html.PartialAsync("Logged/_MenuDashboardLogged")

    <!-- MENÚ USUARIO -->
    <ul class="navbar-nav ms-auto">

        <li class="nav-item dropdown">

            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 text-dark"
               href="#"
               id="userDropdown"
               role="button"
               data-bs-toggle="dropdown"
               aria-expanded="false">

                <span>Bienvenido: @firstName</span>

                <span class="role-badge">
                    @rol
                </span>

                <img src="@profileImageUrl"
                     alt="Foto perfil"
                     class="rounded-circle user-profile-img" />

            </a>

            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">

                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center"
                       asp-controller="Home"
                       asp-action="EditarPerfil">

                        <span>Editar mis datos</span>
                        <i class="fas fa-user-edit ms-3"></i>

                    </a>
                </li>

                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center"
                       asp-controller="Home"
                       asp-action="Logout">

                        <span>Salir</span>
                        <i class="fas fa-sign-out-alt"></i>

                    </a>
                </li>

            </ul>

        </li>

    </ul>

</div>