<!DOCTYPE html>
<html lang="es-ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>INGESOL</title>

    <!-- Estilos propios -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Favicons -->
    <link rel="icon" href="~/assets/img/favicon.ico" />
    <link rel="apple-touch-icon" href="~/assets/img/apple-touch-icon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Montserrat:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <!-- Vendor CSS -->
    <link rel="stylesheet" href="~/assets/vendor/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/vendor/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/assets/vendor/aos/aos.css" />
    <link rel="stylesheet" href="~/assets/vendor/swiper/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/assets/vendor/glightbox/css/glightbox.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Main CSS Landing -->
    <link rel="stylesheet" href="~/assets/css/main.css" asp-append-version="true" />
</head>

    <body class="index-page">

        <!-- HEADER -->
        <header id="header" class="header fixed-top">
            <div class="nav-wrap">
                <nav class="navbar navbar-expand-md navbar-dark">

                    <div class="container-fluid d-flex align-items-center justify-content-between" style="background-color: transparent;">

                        <!-- LOGO -->
                        <div class="d-flex align-items-center">
                            <a class="navbar-brand"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                <img src="/LogoIngesol.png"
                                     alt="Logo"
                                     class="logo-hover-effect"
                                     style="width: 200px; height: 40px; margin-left: 15px;" />
                            </a>
                        </div>

                        <!-- HAMBURGUESA -->
                        <button class="navbar-toggler"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#mainNavbar"
                                aria-controls="mainNavbar"
                                aria-expanded="false"
                                aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <!-- MENÚ -->
                        <div class="collapse navbar-collapse justify-content-between" id="mainNavbar">

                            <ul class="navbar-nav mx-auto">

                                <li class="nav-item">
                                    <a class="nav-link text-dark active" href="#hero">Home</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#about">Empresa</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#clients">Clientes</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#features">Servicios</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#features-cards">Tarjeta de Servicios</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#portfolio">Proyectos</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#cta-testimonials">Testimonios</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#services">Servicios Extra</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#pricing">Planes</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#faq">Que Hacemos?</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#portfolio">Portfolio</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#team">Equipo</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="#contact">Contacto</a>
                                </li>

                            </ul>

                            <!-- DERECHA -->
                            <div class="d-flex align-items-center gap-3 ms-xl-3">

                                <div class="d-flex gap-3">
                                    <a href="#" class="btn-register">
                                        <i class="bi bi-facebook"></i>
                                    </a>
                                    <a href="#" class="btn-register">
                                        <i class="bi bi-twitter-x"></i>
                                    </a>
                                    <a href="#" class="btn-register">
                                        <i class="bi bi-instagram"></i>
                                    </a>
                                </div>

                                <a asp-controller="Home"
                                   asp-action="Login"
                                   class="btn btn-outline-light btn-sm">
                                    Ingresar
                                </a>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <!-- MAIN -->
        <main class="main">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="border-top footer text-muted" style="background: rgba(0, 0, 0, 0.6); padding: 10px 0;">
            <div class="container text-center">
                <span style="color: #ffffff; font-weight: bold;">&copy; 2025 - WebIngesol</span> |
                <a asp-controller="Home"
                   asp-action="Privacy"
                   style="color: #dddddd; text-decoration: none;">
                    Política de Privacidad
                </a>
                <br>
                <small style="color: #bbbbbb; font-style: italic;">
                    Desarrollo y diseño: Carlos M. Espíndola
                </small>
            </div>
        </footer>

        <!-- Scroll Top -->
        <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
            <i class="bi bi-arrow-up-short"></i>
        </a>

        <!-- Vendor JS -->
        <script src="~/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="~/assets/vendor/aos/aos.js"></script>
        <script src="~/assets/vendor/swiper/swiper-bundle.min.js"></script>
        <script src="~/assets/vendor/glightbox/js/glightbox.min.js"></script>
        <script src="~/assets/vendor/purecounter/purecounter_vanilla.js"></script>

        <!-- SweetAlert2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        @RenderSection("Scripts", required: false)

        <!-- JS específico del Home -->
        <script src="~/js/functionsIndexV2.js" asp-append-version="true"></script>

        <!-- Main JS Landing -->
        <script src="~/assets/js/main.js" asp-append-version="true"></script>

        <script>
            document.addEventListener("DOMContentLoaded", function () {

                const links = document.querySelectorAll("#header .nav-link");
                const navbarCollapse = document.getElementById("mainNavbar");

                function setActiveLink() {
                    const currentHash = window.location.hash || "#hero";

                    links.forEach(link => {
                        link.classList.remove("active");

                        if (link.getAttribute("href") === currentHash) {
                            link.classList.add("active");
                        }
                    });
                }

                // al cargar
                setActiveLink();

                links.forEach(link => {
                    link.addEventListener("click", function () {

                        // Active
                        links.forEach(l => l.classList.remove("active"));
                        this.classList.add("active");

                        // CERRAR MENÚ SI ESTÁ ABIERTO
                        if (navbarCollapse.classList.contains("show")) {
                            const bsCollapse = bootstrap.Collapse.getInstance(navbarCollapse)
                                || new bootstrap.Collapse(navbarCollapse);

                            bsCollapse.hide();
                        }
                    });
                });

                window.addEventListener("hashchange", setActiveLink);

            });
        </script>

    <script type="text/javascript" src="https://cdn.emailjs.com/dist/email.min.js"></script>

        <!-- Script propio (SIEMPRE al final) -->
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await Html.PartialAsync("Modals/_ClientModal")

   
    </body>

</html>
